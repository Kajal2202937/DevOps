# ===========================
# Backend .gitignore
# ===========================

# Dependencies
node_modules/

# Environment files — NEVER commit these
.env
.env.local
.env.development
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Runtime
pids/
*.pid
*.seed
